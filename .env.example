# 本地 PostgreSQL（与 prisma/schema 一致）
# 例：docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=happy postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/happy"
# 迁移用直连；本机可与上一行相同。Neon：Dashboard「Direct」串；运行时「Pooled」可填 DATABASE_URL
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/happy"

# 可选：固定演示用户 id（不设则取库内最早用户）
# DEFAULT_USER_ID=

# ---------- 可选登录（默认关闭，不设即演示模式）----------
# AUTH_ENABLED=true
# DEMO_LOGIN_SECRET=your-secret-passphrase
# AUTH_SECRET=openssl-rand-base64-32
# NEXTAUTH_SECRET=与 AUTH_SECRET 相同亦可（兼容旧名）
